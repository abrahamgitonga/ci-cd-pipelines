                echo 'Building...'
            }
        }
        stage('Test'){
            steps{
                echo 'Testing...'
            }
        }
        stage('Deploy'){
            steps{
                echo 'Deploying...'
            }
        }
        stage('Cleanup'){
            steps{
                echo 'Cleaning up...'
            }
        }
        stage('Final Stage'){
            steps{
                echo 'Finalizing...'
            }
        }
        stage('Post Stage'){
            steps{
                echo 'Post-processing...'
            }
        }
    }
}